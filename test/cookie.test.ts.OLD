import { pushProfile, fetchProfile, COOKIE_NAME } from "../src/engine/cookie";
import { DEFAULT_PROFILE } from "../src/profile/default";

/**
 * CookieStore has not yet been implemented in jsdom, we cannot test real cookies.
 */

describe("pushProfile", () => {
    it("should set a cookie with the correct name and value", async () => {
        await pushProfile(DEFAULT_PROFILE)
        expect(document.cookie).toContain(COOKIE_NAME);
    })
})